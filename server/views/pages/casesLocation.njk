{% extends "partials/layout.njk" %}
{% from "em-map/macro.njk" import emMap %}
{% from "components/moj-api-error/macro.njk" import mojApiError %}

{% set pageTitle = applicationName + " - Cases" %}
{% set mainClasses = "app-container govuk-body" %}

{% block beforeContent %}
  {% include "partials/primaryHeader.njk" %}
{% endblock %}

{% block content %}

  {% if locationAlert and locationAlert.text %}
    {{ mojApiError({
      text: locationAlert.text,
      attributes: {
        "data-qa": "location-data-error"
      }
    }) }}    
  {% endif %}
    
  {% include "partials/casesHeader.njk" %}
  {% include "partials/popAlert.njk" %}
  {% include "partials/casesSubNavigation.njk" %}
  <div class="location-activity">
    <h2 class="govuk-heading-m">Location activity</h2>
    <div class="date-time-picker">
      <div class="govuk-grid-row">
        {% include "partials/mapSearchForm.njk" %}
      </div>
    </div>
    <div class="em-map" 
        data-qa="em-map" 
        role="region" 
        aria-label="Interactive map" aria-describedby="map-instructions"
        tabindex="0">

        <span id="map-instructions" class="govuk-visually-hidden">
          Use arrow keys to pan, plus and minus to zoom.
        </span>
        <div id="map-pan-announce" aria-live="polite" aria-atomic="true" class="govuk-visually-hidden"></div>
        <div id="map-rotation-status" aria-live="polite" aria-atomic="true" class="govuk-visually-hidden"></div>
        {{
          emMap({
            alerts: alerts,
            cspNonce: cspNonce,
            positions: positions,
            usesInternalOverlays: true,
            controls: {
              scaleControl: 'bar',
              locationDisplay: 'dms',
              rotateControl: 'true',
              zoomSlider: true
            }
          })
        }}

       {% raw %}
  <template id="overlay-title-mdss-location">
    <div><strong>Point {{ displayPointNumber }}</strong></div>
  </template>

  <template id="overlay-body-mdss-location">
    <div class="app-map__overlay-row">
      <span class="app-map__overlay-label">Accuracy</span>
      <span class="app-map__overlay-value">{{ precision }} meters</span>
    </div>
    <div class="app-map__overlay-row">
      <span class="app-map__overlay-label">Date / time</span>
      <span class="app-map__overlay-value">{{ displayGpsDate }}</span>
    </div>
    <div class="app-map__overlay-row">
      <span class="app-map__overlay-label">Lat / Lng</span>
      <span class="app-map__overlay-value app-map__overlay-value--coords">{{ latitude }}, {{ longitude }}</span>
    </div>
  </template>
{% endraw %}

        <script nonce="{{ cspNonce }}">
          document.addEventListener('DOMContentLoaded', () => {
            const emMap = document.querySelector('em-map')
            if (!emMap) return

            const applyStyles = () => {
              const shadowRoot = emMap.shadowRoot
              if (!shadowRoot) return false

              const sheet = new CSSStyleSheet()
              
sheet.replaceSync(`
  .app-map__overlay {
    border-radius: 16px !important;
    /* Removed overflow: hidden to allow the triangle pointer to show */
    min-width: 270px !important;
    filter: drop-shadow(0 2px 8px rgba(0,0,0,0.15)) !important;
  }
  
  /* Ensure the header still respects the border radius since we removed overflow:hidden */
  .app-map__overlay-header {
    border-radius: 16px 16px 0 0 !important;
  }

  .app-map__overlay-body {
    padding: 0 !important;
    background: white !important;
    border-radius: 0 0 16px 16px !important;
  }

  .app-map__overlay-row {
    background-color: transparent !important;
    border-top: none !important;
    border-bottom: 0.5px solid #d9d9d9 !important;
    padding: 5px 10px !important; /* Increased slightly for better look */
    margin: 0 !important;
    display: flex !important;
    align-items: center !important;
    /* Gap controls the space between label and value */
    gap: 15px !important; 
  }

  .app-map__overlay-row:last-of-type {
    border-bottom: none !important;
  }

  .app-map__overlay-label {
    /* Changed from 25% to auto to reduce the purple gap */
    flex: 0 0 auto !important;
    min-width: 70px !important; 
    font-weight: 700 !important;
    font-size: 14px !important;
    color: #0b0c0c !important;
  }

  .app-map__overlay-value {
    font-size: 14px !important;
    color: #0b0c0c !important;
    flex: 1 !important; /* Allows value to take up remaining space */
  }

  .app-map__overlay-value--coords {
    background: #f3f2f1 !important;
    border-radius: 4px !important;
    padding: 4px 10px !important;
    font-size: 13px !important;
    display: inline-block !important;

    white-space: nowrap !important;  
    width: max-content !important;  
  }

  a, a:visited, a:link {
    color: #1d70b8 !important;
    text-decoration: underline !important;
    font-size: 14px !important;
  }
`)
              shadowRoot.adoptedStyleSheets = [...shadowRoot.adoptedStyleSheets, sheet]
              return true
            }

            if (!applyStyles()) {
              const observer = new MutationObserver(() => {
                if (applyStyles()) observer.disconnect()
              })
              observer.observe(emMap, { childList: true, subtree: true })
            }
          })
        </script>
     
    </div>
    <p class="govuk-body-m"><a href="/map-help">Guide to the map</a></p>
  </div>
{% endblock %}