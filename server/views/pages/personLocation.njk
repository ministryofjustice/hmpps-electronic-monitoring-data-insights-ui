{% extends "../partials/layout.njk" %}
{% extends "moj/template.njk" %}

{% set pageTitle = applicationName + " - Person Location" %}
{% set mainClasses = "app-container govuk-body" %}

{% block beforeContent %}
  {% include "../partials/primaryHeader.njk" %}
{% endblock %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% include "partials/casesHeader.njk" %}
      <h1 class="govuk-heading-xl govuk-!-margin-top-6">Location</h1>

      <dl class="govuk-summary-list">
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Person ID</dt>
          <dd class="govuk-summary-list__value">{{ personContext.personId }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Consumer ID</dt>
          <dd class="govuk-summary-list__value">{{ personContext.consumerId }}</dd>
        </div>
        <div class="govuk-summary-list__row">
          <dt class="govuk-summary-list__key">Delius ID</dt>
          <dd class="govuk-summary-list__value">{{ popData.crn }}</dd>
        </div>
      </dl>
    </div>
  </div>
{% endblock %}
